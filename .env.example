# ── Alpaca (paper trading) ───────────────────────────────────────────
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Anthropic (the brain) ────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Finnhub (news) ───────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here

# ── Financial Modeling Prep (fundamentals) — OPTIONAL ────────────────
FMP_API_KEY=

# ── Twilio (SMS trade alerts) — OPTIONAL but recommended ─────────────
# https://www.twilio.com  (free trial credit; ~$1/mo for a number +
# ~$0.0079 per SMS after). Leave blank to fall back to console alerts.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=         # your Twilio number, e.g. +15551234567
ALERT_TO_NUMBER=            # your phone, e.g. +15559876543

# ── Multi-user (BYOK) ────────────────────────────────────────────────
# Generate with: python run.py users keygen
MASTER_ENCRYPTION_KEY=

# ── Production DB backend (Supabase Postgres) — OPTIONAL ──────────────
# If set, the worker reads/writes Supabase (same data the web app uses) via the
# service-role / direct connection string. If unset, it uses local SQLite.
DATABASE_URL=

# ── Global pause switch ───────────────────────────────────────────────
# Set to "true" to stop ALL cycles (single- and multi-user). Per-user pausing is
# done in the dashboard or `python run.py users pause --user <id>`.
BUDDY_PAUSED=false

# ── Telegram alerts (free) — OPTIONAL ────────────────────────────────
# Create a bot via @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email alerts (SMTP) — OPTIONAL ───────────────────────────────────
# Enable by adding "email" to notify.channels. Gmail App Passwords work reliably
# for SMTP; Outlook personal accounts often block basic auth, so Gmail is the
# safer SENDER. EMAIL_TO may be a comma-separated list to alert several inboxes.
SMTP_HOST=                 # e.g. smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=                 # an App Password, not your normal password
SMTP_FROM=                 # defaults to SMTP_USER if blank
EMAIL_TO=                  # e.g. you@outlook.com,you@gmail.com
