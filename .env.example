# ── Alpaca (paper trading) ───────────────────────────────────────────
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Anthropic (the brain) ────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Finnhub (news) ───────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here

# ── Financial Modeling Prep (fundamentals) — OPTIONAL ────────────────
FMP_API_KEY=

# ── Twilio (SMS trade alerts) — OPTIONAL but recommended ─────────────
# https://www.twilio.com  (free trial credit; ~$1/mo for a number +
# ~$0.0079 per SMS after). Leave blank to fall back to console alerts.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=         # your Twilio number, e.g. +15551234567
ALERT_TO_NUMBER=            # your phone, e.g. +15559876543

# ── Multi-user (BYOK) ────────────────────────────────────────────────
# Generate with: python run.py users keygen
MASTER_ENCRYPTION_KEY=

# ── Telegram alerts (free) — OPTIONAL ────────────────────────────────
# Create a bot via @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
