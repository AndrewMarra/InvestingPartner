# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only secrets (NO NEXT_PUBLIC_ prefix -> never sent to the browser).
# MUST match the value used by the Python worker so it can encrypt/decrypt BYOK
# keys (used by both key-save AND the explore page's per-user key decryption).
MASTER_ENCRYPTION_KEY=your_fernet_master_key

# Optional: model for the explore page's "buddy's take" (advisory). Defaults to
# claude-sonnet-4-6. Keep it in sync with config.yaml models.decision_model.
DECISION_MODEL=claude-sonnet-4-6
